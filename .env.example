# Copy to .env.local and fill in what you have. Every integration below runs
# in a safe mock/sandbox mode when its variables are missing — nothing
# crashes without keys, see src/lib/integrations/*.

# --- Modules (set to "false" to disable any module) ---
# NEXT_PUBLIC_MODULE_AICONCIERGE=false

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Supabase (auth, database, storage, RLS, edge functions) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenAI (AI Concierge, AI Local Guide, AI Manager, AI Content Studio) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Email (pick one) ---
RESEND_API_KEY=
SENDGRID_API_KEY=
EMAIL_FROM=rezervari@your-domain.com

# --- WhatsApp Business Cloud API ---
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_ID=

# --- Maps & Weather ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# --- Payments ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
REVOLUT_API_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# --- Calendar sync ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# --- Analytics ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# --- Future channel manager integrations ---
BOOKING_COM_API_KEY=
AIRBNB_API_KEY=
EXPEDIA_API_KEY=
